# =============================================================================
# COMMON — runtime & infrastructure (all services)
# =============================================================================

# Runtime: SIMULATE | LIVE. BACKTEST_ENABLED=true requires SIMULATE.
TRADING_MODE=SIMULATE

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
TOPIC_STRATEGY_SIGNAL=BTCUSDT.strategy.signal
TOPIC_SIMULATE_REPLAY=BTCUSDT.simulate.replay
KAFKA_GROUP_EXECUTE=execute-service-live
KAFKA_GROUP_SIMULATE=simulate-service
KAFKA_GROUP_SIMULATE_REPLAY=simulate-service-replay

# Service ports
STRATEGY_PORT=8081
EXECUTE_PORT=8082
SIMULATE_PORT=8083

# Remote debug (JDWP). Host ports map to container :5005.
STRATEGY_DEBUG_PORT=5005
EXECUTE_DEBUG_PORT=5006
SIMULATE_DEBUG_PORT=5007
# Override JVM opts to disable debug, e.g. STRATEGY_JAVA_OPTS=
#STRATEGY_JAVA_OPTS=-agentlib:jdwp=transport=dt_socket,server=y,suspend=n,address=*:5005
#EXECUTE_JAVA_OPTS=-agentlib:jdwp=transport=dt_socket,server=y,suspend=n,address=*:5005
#SIMULATE_JAVA_OPTS=-agentlib:jdwp=transport=dt_socket,server=y,suspend=n,address=*:5005

# Backtest orchestration (strategy-service; simulate/execute validate flag)
BACKTEST_ENABLED=false
BACKTEST_STANDALONE_EXIT=true
BACKTEST_CLI_ON_STARTUP=false
BACKTEST_OHLC_ORDER=OHLC

# Market data (strategy-service WS/REST; execute-service REST)
BINANCE_REST_BASE_URL=https://fapi.binance.com
BINANCE_WS_BASE_URL=wss://fstream.binance.com
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
REST_KLINE_LIMIT=500
WS_ENABLED=true

# Databases (schema-per-service on one Postgres instance)
STRATEGY_DB_URL=jdbc:postgresql://postgres:5432/trading
STRATEGY_DB_USER=trading
STRATEGY_DB_PASSWORD=trading
EXECUTE_DB_URL=jdbc:postgresql://postgres:5432/trading
EXECUTE_DB_USER=trading
EXECUTE_DB_PASSWORD=trading
SIMULATE_DB_URL=jdbc:postgresql://postgres:5432/trading
SIMULATE_DB_USER=trading
SIMULATE_DB_PASSWORD=trading

# =============================================================================
# COMMON — trading (strategy-service + execute-service + simulate-service)
# =============================================================================

SYMBOL=BTCUSDT
KLINE_INTERVAL=15m
LEVERAGE=20
TAKER_FEE=0.0005

# Signal cadence — all strategy types (strategy-service)
STRATEGY_TRIGGER_MS=2000
MIN_SIGNAL_INTERVAL_MS=10000

# Admin / latency guard — execute-service + simulate-service
ADMIN_TOKEN=change-me
LATENCY_WARN_MS=1000
LATENCY_BLOCK_MS=5000

# Position sizing — execute-service + simulate-service
SIZING_MODE=PERCENT
SIZING_ACCOUNT_PERCENT=0.01
SIZING_MAX_ACCOUNT_PERCENT=0.02
SIZING_FIXED_NOTIONAL_USDT=20

# =============================================================================
# STRATEGY selector (strategy-service)
# =============================================================================
# peak-trough | vortex-scalping
STRATEGY_TYPE=peak-trough

# =============================================================================
# STRATEGY: peak-trough (strategy-service)
# Ignored when STRATEGY_TYPE=vortex-scalping
# =============================================================================

STRATEGY_N=500
STRATEGY_K=2
SIMILARITY_THRESHOLD=0.001
FEE_GATE_MULTIPLIER=4.0

# =============================================================================
# STRATEGY: vortex-scalping (strategy-service)
# Ignored when STRATEGY_TYPE=peak-trough
# =============================================================================

VORTEX_RSI_OVERSOLD=40
VORTEX_RSI_OVERBOUGHT=60
VORTEX_EMA_PERIOD=20
VORTEX_RSI_PERIOD=14
# VORTEX_VOLUME_LOOKBACK=5
# VORTEX_TAKER_BUY_MULT=1.5
# VORTEX_BUY_RATIO_DROP=0.7

# =============================================================================
# simulate-service — paper trading
# =============================================================================

SIM_INITIAL_BALANCE_USDT=500
SIM_LIQUIDATION_MARGIN_LOSS_THRESHOLD=0.8
# TP/SL as decimal rate (0.003 = 0.3%). If <= 0, fallback: FEE_GATE_MULTIPLIER x TAKER_FEE x multiplier
SIM_TP_PERCENT=0.005
SIM_SL_PERCENT=0.003
SIM_TP_MULTIPLIER=1.0
SIM_SL_MULTIPLIER=1.0

# =============================================================================
# execute-service — live trading & risk
# =============================================================================

RISK_MAX_LOSS_PERCENT=0.20
RISK_BUCKET_HOURS=24
RECONCILIATION_SYNC_MS=30000
RECONCILIATION_DRIFT_USDT=0.5
