# Preset: vortex-scalping strategy (copy/rename to .env or merge sections)
# See .env.example for full annotated template.

# =============================================================================
# COMMON — runtime & infrastructure (all services)
# =============================================================================

TRADING_MODE=SIMULATE

KAFKA_BOOTSTRAP_SERVERS=kafka:9092
TOPIC_STRATEGY_SIGNAL=BTCUSDT.strategy.signal
TOPIC_SIMULATE_REPLAY=BTCUSDT.simulate.replay
KAFKA_GROUP_EXECUTE=execute-service-live
KAFKA_GROUP_SIMULATE=simulate-service

STRATEGY_PORT=8081
EXECUTE_PORT=8082
SIMULATE_PORT=8083

BACKTEST_ENABLED=true
BACKTEST_STANDALONE_EXIT=true
BACKTEST_OHLC_ORDER=OHLC

BINANCE_REST_BASE_URL=https://fapi.binance.com
BINANCE_WS_BASE_URL=wss://fstream.binance.com
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
REST_KLINE_LIMIT=500
WS_ENABLED=true

STRATEGY_DB_URL=jdbc:postgresql://postgres:5432/trading
STRATEGY_DB_USER=trading
STRATEGY_DB_PASSWORD=trading
EXECUTE_DB_URL=jdbc:postgresql://postgres:5432/trading
EXECUTE_DB_USER=trading
EXECUTE_DB_PASSWORD=trading
SIMULATE_DB_URL=jdbc:postgresql://postgres:5432/trading
SIMULATE_DB_USER=trading
SIMULATE_DB_PASSWORD=trading

# =============================================================================
# COMMON — trading (strategy-service + execute-service + simulate-service)
# =============================================================================

SYMBOL=BTCUSDT
KLINE_INTERVAL=1h
LEVERAGE=20
TAKER_FEE=0.0005
STRATEGY_TRIGGER_MS=2000
MIN_SIGNAL_INTERVAL_MS=10000
ADMIN_TOKEN=change-me
LATENCY_WARN_MS=1000
LATENCY_BLOCK_MS=5000
SIZING_MODE=PERCENT
SIZING_ACCOUNT_PERCENT=0.01
SIZING_MAX_ACCOUNT_PERCENT=0.02
SIZING_FIXED_NOTIONAL_USDT=20

# =============================================================================
# STRATEGY selector (strategy-service)
# =============================================================================

STRATEGY_TYPE=vortex-scalping

# =============================================================================
# STRATEGY: peak-trough — inactive for this preset
# =============================================================================

# STRATEGY_N=500
# STRATEGY_K=2
# SIMILARITY_THRESHOLD=0.001
# FEE_GATE_MULTIPLIER=4.0

# =============================================================================
# STRATEGY: vortex-scalping (strategy-service)
# =============================================================================

VORTEX_RSI_OVERSOLD=40
VORTEX_RSI_OVERBOUGHT=60
VORTEX_EMA_PERIOD=99
VORTEX_RSI_PERIOD=14

# =============================================================================
# simulate-service — paper trading
# =============================================================================

SIM_INITIAL_BALANCE_USDT=500
SIM_LIQUIDATION_MARGIN_LOSS_THRESHOLD=0.8
SIM_TP_PERCENT=0.005
SIM_SL_PERCENT=0.003
SIM_TP_MULTIPLIER=1
SIM_SL_MULTIPLIER=3

# =============================================================================
# execute-service — live trading & risk
# =============================================================================

RISK_MAX_LOSS_PERCENT=0.20
RISK_BUCKET_HOURS=24
RECONCILIATION_SYNC_MS=30000
RECONCILIATION_DRIFT_USDT=0.5
